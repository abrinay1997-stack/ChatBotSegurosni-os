TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWLIST=        # chat_ids separados por coma; vacío = sin allowlist en dev
LLM_PROVIDER=groq          # groq | glm | nvidia — proveedor primario
LLM_FALLBACK_PROVIDER=     # opcional: groq | glm | nvidia — si el primario falla (429/5xx/timeout), reintenta con este
GROQ_API_KEY=
GLM_API_KEY=
NVIDIA_API_KEY=            # necesaria si nvidia es primario o fallback
NVIDIA_MODEL=             # opcional, default meta/llama-3.1-8b-instruct (rápido, ~1.7s). NO usar 70b en serverless: ~12.8s supera el timeout de 10s de Netlify
DATABASE_URL=              # connection string de Postgres (Neon), ver INSTALL.md
LLM_DAILY_BUDGET_USD=5
LLM_PROVIDER_RESIDENT_ONLY=false
PROMPT_VERSION=v1
PROMPT_AB=control
LOG_LEVEL=info
NODE_ENV=development
PORT=3000
