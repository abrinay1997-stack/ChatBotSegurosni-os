TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWLIST=        # chat_ids separados por coma; vacío = sin allowlist en dev
LLM_PROVIDER=groq          # groq | glm
GROQ_API_KEY=
GLM_API_KEY=
NVIDIA_API_KEY=            # opcional — si está seteada, se usa como fallback automático (kimi-k2.6) cuando el proveedor primario falla
DATABASE_URL=              # connection string de Postgres (Neon), ver INSTALL.md
LLM_DAILY_BUDGET_USD=5
LLM_PROVIDER_RESIDENT_ONLY=false
PROMPT_VERSION=v1
PROMPT_AB=control
LOG_LEVEL=info
NODE_ENV=development
PORT=3000
